# ─────────────────────────────────────────────────────────────────────────────
# DAA v3.0 Environment Configuration
# Copy this file to .env and fill in your values.
# Run `daa init` for a guided interactive setup wizard.
# Full reference: DEPLOYMENT.md
# ─────────────────────────────────────────────────────────────────────────────

# ── Core ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-secret-key

# ── Deployment Mode Toggles ──────────────────────────────────────────────────
# DAA_DB_PROVIDER: none | sqlite | postgres | internal-postgres | external-postgres
#                  internal-redis | external-redis  (Redis: planned, not active yet)
DAA_DB_PROVIDER=sqlite

# DAA_GIT_MODE: api (read/write via REST, no cloning) | local (git clone worktrees)
DAA_GIT_MODE=local

# DAA_QUEUE_MODE: sync (inline background tasks) | rabbitmq (distributed queue)
DAA_QUEUE_MODE=sync

# DAA_AUTH_ENABLED: true | false  (JWT-based login portal)
DAA_AUTH_ENABLED=false

# DAA_POLICY_ENABLED: true | false  (sliding-window escalation policies)
DAA_POLICY_ENABLED=false

# DAA_HITL_MODE: true | false  (Human-in-the-Loop — defer PR creation for manual approval)
DAA_HITL_MODE=false

# DAA_AGENT_MODE: full | fast  (full = 4-dimension loop; fast = quick fix only)
DAA_AGENT_MODE=full

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL (used when DAA_DB_PROVIDER=postgres or internal-postgres)
POSTGRES_PASSWORD=yourpostgrespassword
DATABASE_URL=postgresql://postgres:yourpostgrespassword@postgres:5432/daa

# ── Queue (RabbitMQ) ─────────────────────────────────────────────────────────
# Used when DAA_QUEUE_MODE=rabbitmq
RABBITMQ_HOST=rabbitmq
RABBITMQ_QUEUE=fix_jobs

# ── Cache (Redis) ─────────────────────────────────────────────────────────────
# NOTE: Redis support is planned for a future branch (DAA 3.1).
# These variables are reserved and not active in the current release.
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Set LLM_PROVIDER to one of:
#   google     → Google Gemini (default, recommended)
#   openai     → OpenAI GPT-4o
#   anthropic  → Anthropic Claude
#   vertex     → Google Cloud Vertex AI (requires `gcloud auth application-default login`)
#   openclaw   → OpenClaw / LiteLLM proxy (OAuth bearer token / sign-in code)
#   ollama     → Local Ollama (fully air-gapped)
#   agy        → Antigravity CLI proxy (no key leak risk)

LLM_PROVIDER=google

# API key for the selected provider:
LLM_API_KEY=
# Or use provider-specific env vars:
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Model name (optional — DAA picks a sensible default per provider):
LLM_MODEL=
# Examples: gemini-2.5-flash / gpt-4o / claude-3-5-sonnet-20241022 / llama3

# Base URL for proxy providers (OpenClaw, LiteLLM, Ollama):
LLM_BASE_URL=
# Examples: http://localhost:4000 (LiteLLM) / http://localhost:11434/v1 (Ollama)

# ── Agent Safety ─────────────────────────────────────────────────────────────
# Maximum number of reasoning iterations the agent may take:
DAA_MAX_ITERATIONS=10

# Hard cap on tool calls (DAA 3.0 safety system):
DAA_MAX_TOOL_CALLS=8
DAA_TOOL_CALL_WARNING_AT=5

# ── MCP (Model Context Protocol) ─────────────────────────────────────────────
# External MCP tools configuration for Serverless (memory JSON) vs Full-Stack (file path).
# Note: DAA always maintains dual-layer safety by keeping native Git and local diagnostic
# tools active as a fallback if external MCP servers fail health checks (`-32002`).
# For Serverless / Cloud Run mode (pass inline JSON directly without volume mounts):
DAA_MCP_CONFIG_JSON=
# For Full-Stack / Docker Compose mode (path to mounted JSON config file):
DAA_MCP_CONFIG_PATH=mcp_config.json

# ── Git Provider ──────────────────────────────────────────────────────────────
# Target repository URL (used for stateless/API mode):
DAA_REPO_URL=

# GitHub
GITHUB_TOKEN=
GITHUB_REPO=owner/repo   # Used for GitHub Issues fallback ticketing

# GitLab (for self-hosted or GitLab.com)
GITLAB_HOST=https://gitlab.com
GITLAB_PRIVATE_TOKEN=
GITLAB_USER=root
GITLAB_ROOT_PASSWORD=

# Gitea (local forge, used in E2E demo)
GITEA_HOST=http://localhost:3000
GITEA_TOKEN=

# Bitbucket
BITBUCKET_USERNAME=
BITBUCKET_APP_PASSWORD=

# ── Incident Ticketing ────────────────────────────────────────────────────────
# Jira Cloud (primary — DAA will create real tickets when it can't auto-fix)
JIRA_URL=https://yourorg.atlassian.net
JIRA_EMAIL=you@yourorg.com
JIRA_TOKEN=
JIRA_PROJECT_KEY=ENG

# If Jira is not set, DAA falls back to GitHub Issues (uses GITHUB_TOKEN + GITHUB_REPO)

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins:
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:5003
# LAN_HOST_IP is your machine's local network IP (for LAN access):
LAN_HOST_IP=192.168.1.41

# ── Webhook Auth ─────────────────────────────────────────────────────────────
# Optional API key to protect /ingest/* endpoints:
DAA_API_KEY=
# Optional Sentry webhook signature secret:
SENTRY_WEBHOOK_SECRET=

# ── SDK / App Registration ────────────────────────────────────────────────────
DAA_TOKEN=          # JWT token for SDK/service authentication
REPO_NAME=test-app  # Repository name used by test app

# ── Admin Panel ───────────────────────────────────────────────────────────────
REACT_APP_API_URL=http://localhost:8000

# ── Internal Services ─────────────────────────────────────────────────────────
# URL for the python-agent to call the backend API:
DAA_BACKEND_API_URL=http://backend-api:80

# ── Self-Reporting (opt-in) ───────────────────────────────────────────────────
# If true, DAA sends anonymous internal error reports to help improve the platform.
# No user data, logs, or secrets are ever transmitted — only DAA-internal exceptions.
DAA_SELF_REPORT=false
