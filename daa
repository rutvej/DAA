#!/usr/bin/env python3
"""
daa — DAA v2.0 Autonomous SRE Platform CLI
==========================================
Usage:
  daa init                  Guided setup wizard (Git, LLM, Cloud Logging)
  daa register              Register an application with DAA
  daa policy                Configure application escalation policies
  daa mcp list              List configured Model Context Protocol servers
  daa mcp add               Add a new Model Context Protocol server
  daa mcp remove            Remove a Model Context Protocol server
  daa config set-model      Update model and credentials configuration
  daa redeploy              Restart and rebuild DAA containers to apply changes
  daa status                Health check all DAA services
  daa test                  Send a test error to verify the pipeline
  daa logs                  Stream recent incident logs
  daa version               Show version
"""

import os
import sys
import json
import time
import argparse
import subprocess
import getpass
from typing import Dict, Any

try:
    import requests
except ImportError:
    print("❌ 'requests' not installed. Run: pip install requests")
    sys.exit(1)

VERSION = "2.0.0"
CONFIG_FILE = os.path.expanduser("~/.daa/config.json")
DEFAULT_BACKEND = "http://localhost:8000"

BOLD = "\033[1m"
GREEN = "\033[92m"
YELLOW = "\033[93m"
RED = "\033[91m"
CYAN = "\033[96m"
DIM = "\033[2m"
RESET = "\033[0m"


# ─────────────────────────────────────────────
# Helpers
# ─────────────────────────────────────────────

def ok(msg): print(f"{GREEN}✔{RESET} {msg}")
def warn(msg): print(f"{YELLOW}⚠{RESET}  {msg}")
def err(msg): print(f"{RED}✖{RESET} {msg}")
def info(msg): print(f"{CYAN}→{RESET} {msg}")
def header(msg): print(f"\n{BOLD}{msg}{RESET}")


def load_config() -> dict:
    if os.path.exists(CONFIG_FILE):
        try:
            with open(CONFIG_FILE) as f:
                return json.load(f)
        except Exception:
            pass
    return {}


def save_config(cfg: dict):
    os.makedirs(os.path.dirname(CONFIG_FILE), exist_ok=True)
    with open(CONFIG_FILE, "w") as f:
        json.dump(cfg, f, indent=2)
    ok(f"Config saved to {CONFIG_FILE}")


def write_env_vars(env_map: Dict[str, str]):
    """Merges env vars into local .env and .env.daa files for docker-compose config."""
    # Write to .env.daa
    lines = ["# Generated by DAA CLI setup\n"]
    for k, v in env_map.items():
        if v is not None:
            lines.append(f"{k}={v}")
    
    with open(".env.daa", "w") as f:
        f.write("\n".join(lines) + "\n")
    ok("Wrote environment configurations to .env.daa")

    # Update or create .env in local workspace
    existing = {}
    if os.path.exists(".env"):
        with open(".env", "r") as f:
            for line in f:
                line = line.strip()
                if line and not line.startswith("#") and "=" in line:
                    k, v = line.split("=", 1)
                    existing[k.strip()] = v.strip()
    
    # Update with new values
    for k, v in env_map.items():
        if v is not None:
            existing[k] = v
            
    with open(".env", "w") as f:
        f.write("# Deduplicated Autonomous Agent Workspace Env\n")
        for k, v in existing.items():
            f.write(f"{k}={v}\n")
    ok("Updated local .env workspace file")


def get_admin_token(backend_url: str) -> str:
    """Authenticates or registers default testuser admin account on the backend."""
    admin_payload = {"username": "testuser", "password": "testpassword"}
    # Register first (ignore if already exists)
    try:
        requests.post(f"{backend_url}/auth/register", json=admin_payload, timeout=4)
    except Exception:
        pass
    
    # Login
    try:
        res = requests.post(f"{backend_url}/auth/login", json=admin_payload, timeout=4)
        if res.status_code == 200:
            return res.json().get("token") or res.json().get("access_token")
    except Exception as e:
        warn(f"Unable to authenticate as admin on backend: {e}")
    return ""


def get_token() -> str:
    token = os.environ.get("DAA_TOKEN")
    if token:
        return token
    if os.path.exists(".env"):
        with open(".env") as f:
            for line in f:
                if line.startswith("DAA_TOKEN="):
                    return line.split("=", 1)[1].strip()
    return ""


def ask(prompt: str, default: str = "", secret: bool = False) -> str:
    display = f"  {prompt}"
    if default:
        display += f" [{DIM}{default}{RESET}]"
    display += ": "
    if secret:
        val = getpass.getpass(display)
    else:
        val = input(display)
    return val.strip() or default


def ask_choice(prompt: str, choices: list, default: str = "") -> str:
    print(f"  {prompt}")
    for i, c in enumerate(choices, 1):
        marker = f" {GREEN}(default){RESET}" if c == default else ""
        print(f"    {DIM}{i}.{RESET} {c}{marker}")
    while True:
        raw = input(f"  Choose [1-{len(choices)}]: ").strip()
        if not raw and default:
            return default
        if raw.isdigit() and 1 <= int(raw) <= len(choices):
            return choices[int(raw) - 1]
        warn("Invalid choice, try again.")


