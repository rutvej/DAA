#!/usr/bin/env python3
"""
daa — DAA v2.0 Autonomous SRE Platform CLI
==========================================
Usage:
  daa init          Guided setup wizard — connect your stack to DAA
  daa status        Health check all DAA services
  daa test          Send a test error to verify the pipeline end-to-end
  daa logs          Stream recent incident logs
  daa version       Show version

Install globally:
  pip install -e .   (from the repo root)
  or
  chmod +x daa && sudo ln -s $(pwd)/daa /usr/local/bin/daa
"""

import os
import sys
import json
import time
import argparse
import subprocess

try:
    import requests
except ImportError:
    print("❌ 'requests' not installed. Run: pip install requests")
    sys.exit(1)

VERSION = "2.0.0"
CONFIG_FILE = os.path.expanduser("~/.daa/config.json")
DEFAULT_BACKEND = "http://localhost:8000"

BOLD = "\033[1m"
GREEN = "\033[92m"
YELLOW = "\033[93m"
RED = "\033[91m"
CYAN = "\033[96m"
DIM = "\033[2m"
RESET = "\033[0m"


# ─────────────────────────────────────────────
# Helpers
# ─────────────────────────────────────────────

def ok(msg): print(f"{GREEN}✔{RESET} {msg}")
def warn(msg): print(f"{YELLOW}⚠{RESET}  {msg}")
def err(msg): print(f"{RED}✖{RESET} {msg}")
def info(msg): print(f"{CYAN}→{RESET} {msg}")
def header(msg): print(f"\n{BOLD}{msg}{RESET}")


def load_config() -> dict:
    if os.path.exists(CONFIG_FILE):
        with open(CONFIG_FILE) as f:
            return json.load(f)
    return {}


def save_config(cfg: dict):
    os.makedirs(os.path.dirname(CONFIG_FILE), exist_ok=True)
    with open(CONFIG_FILE, "w") as f:
        json.dump(cfg, f, indent=2)
    ok(f"Config saved to {CONFIG_FILE}")


def ask(prompt: str, default: str = "", secret: bool = False) -> str:
    display = f"  {prompt}"
    if default:
        display += f" [{DIM}{default}{RESET}]"
    display += ": "
    if secret:
        import getpass
        val = getpass.getpass(display)
    else:
        val = input(display)
    return val.strip() or default


def ask_choice(prompt: str, choices: list, default: str = "") -> str:
    print(f"  {prompt}")
    for i, c in enumerate(choices, 1):
        marker = f" {GREEN}(default){RESET}" if c == default else ""
        print(f"    {DIM}{i}.{RESET} {c}{marker}")
    while True:
        raw = input(f"  Choose [1-{len(choices)}]: ").strip()
        if not raw and default:
            return default
        if raw.isdigit() and 1 <= int(raw) <= len(choices):
            return choices[int(raw) - 1]
        warn("Invalid choice, try again.")


# ─────────────────────────────────────────────
# Commands
# ─────────────────────────────────────────────

def cmd_version(_args):
    print(f"daa {VERSION} — DAA Autonomous SRE Platform")


def cmd_init(_args):
    header("━━━ DAA v2.0 Setup Wizard ━━━")
    print(f"{DIM}This wizard connects DAA to your LLM provider, Git provider, and ticketing system.{RESET}\n")

    cfg = load_config()

    # ── Step 1: Backend URL ──
    header("Step 1 — DAA Backend")
    backend = ask("DAA backend URL", cfg.get("backend_url", DEFAULT_BACKEND))
    cfg["backend_url"] = backend

    # ── Step 2: LLM Provider ──
    header("Step 2 — LLM Provider")
    provider = ask_choice(
        "Which LLM provider do you want DAA to use?",
        ["google (Gemini)", "openai (GPT-4o)", "anthropic (Claude)", "openclaw / litellm proxy", "ollama (local)"],
        default="google (Gemini)"
    )
    provider_key = provider.split(" ")[0]
    cfg["LLM_PROVIDER"] = provider_key

    if provider_key == "google":
        cfg["LLM_API_KEY"] = ask("Google Gemini API key", cfg.get("LLM_API_KEY", ""), secret=True)
        cfg["LLM_MODEL"] = ask("Model name", cfg.get("LLM_MODEL", "gemini-2.5-flash"))
    elif provider_key == "openai":
        cfg["LLM_API_KEY"] = ask("OpenAI API key (sk-...)", cfg.get("LLM_API_KEY", ""), secret=True)
        cfg["LLM_MODEL"] = ask("Model name", cfg.get("LLM_MODEL", "gpt-4o"))
    elif provider_key == "anthropic":
        cfg["LLM_API_KEY"] = ask("Anthropic API key", cfg.get("LLM_API_KEY", ""), secret=True)
        cfg["LLM_MODEL"] = ask("Model name", cfg.get("LLM_MODEL", "claude-3-5-sonnet-20241022"))
    elif provider_key == "openclaw":
        cfg["LLM_BASE_URL"] = ask("Proxy base URL", cfg.get("LLM_BASE_URL", "http://localhost:4000"))
        cfg["LLM_API_KEY"] = ask("Bearer token / sign-in code", cfg.get("LLM_API_KEY", ""), secret=True)
        cfg["LLM_MODEL"] = ask("Model name", cfg.get("LLM_MODEL", "codex"))
    elif provider_key == "ollama":
        cfg["LLM_BASE_URL"] = ask("Ollama base URL", cfg.get("LLM_BASE_URL", "http://localhost:11434/v1"))
        cfg["LLM_MODEL"] = ask("Model name", cfg.get("LLM_MODEL", "llama3"))

    # ── Step 3: Git Provider ──
    header("Step 3 — Git Provider")
    git_provider = ask_choice(
        "Which Git provider hosts your application repos?",
        ["github", "gitlab (cloud)", "gitlab (self-hosted)"],
        default="github"
    )
    cfg["GIT_PROVIDER"] = git_provider.split(" ")[0]

    if cfg["GIT_PROVIDER"] == "github":
        cfg["GITHUB_TOKEN"] = ask("GitHub Personal Access Token", cfg.get("GITHUB_TOKEN", ""), secret=True)
        cfg["GITHUB_REPO"] = ask("Default repo (owner/repo) for issues", cfg.get("GITHUB_REPO", ""))
    else:
        cfg["GITLAB_HOST"] = ask("GitLab host", cfg.get("GITLAB_HOST", "gitlab.com"))
        cfg["GITLAB_PRIVATE_TOKEN"] = ask("GitLab Personal Access Token", cfg.get("GITLAB_PRIVATE_TOKEN", ""), secret=True)

    # ── Step 4: Ticketing ──
    header("Step 4 — Incident Ticketing (optional)")
    use_jira = ask_choice(
        "Do you want DAA to create real Jira tickets when it can't auto-fix?",
        ["yes", "no — use GitHub Issues", "no — skip ticketing"],
        default="no — use GitHub Issues"
    )

    if use_jira == "yes":
        cfg["JIRA_URL"] = ask("Jira Cloud URL (e.g. https://yourorg.atlassian.net)", cfg.get("JIRA_URL", ""))
        cfg["JIRA_EMAIL"] = ask("Jira account email", cfg.get("JIRA_EMAIL", ""))
        cfg["JIRA_TOKEN"] = ask("Jira API token", cfg.get("JIRA_TOKEN", ""), secret=True)
        cfg["JIRA_PROJECT_KEY"] = ask("Jira project key (e.g. ENG)", cfg.get("JIRA_PROJECT_KEY", ""))

    # ── Step 5: Register first application ──
    header("Step 5 — Register Your First Application")
    app_name = ask("Application name (e.g. checkout-service)", "")
    if app_name:
        cfg["first_app"] = {
            "name": app_name,
            "repo_url": ask("Repository URL", ""),
            "language": ask_choice("Language", ["python", "node", "go", "java", "ruby", "dotnet"], "python"),
            "threshold": ask("Escalate after N errors in 60 seconds", "3"),
        }

    save_config(cfg)

    # Write .env patch
    header("Generating .env entries…")
    env_lines = []
    env_map = {
        "LLM_PROVIDER": cfg.get("LLM_PROVIDER"),
        "LLM_API_KEY": cfg.get("LLM_API_KEY"),
        "LLM_MODEL": cfg.get("LLM_MODEL"),
        "LLM_BASE_URL": cfg.get("LLM_BASE_URL"),
        "GITHUB_TOKEN": cfg.get("GITHUB_TOKEN"),
        "GITHUB_REPO": cfg.get("GITHUB_REPO"),
        "GITLAB_HOST": cfg.get("GITLAB_HOST"),
        "GITLAB_PRIVATE_TOKEN": cfg.get("GITLAB_PRIVATE_TOKEN"),
        "JIRA_URL": cfg.get("JIRA_URL"),
        "JIRA_EMAIL": cfg.get("JIRA_EMAIL"),
        "JIRA_TOKEN": cfg.get("JIRA_TOKEN"),
        "JIRA_PROJECT_KEY": cfg.get("JIRA_PROJECT_KEY"),
    }
    for k, v in env_map.items():
        if v:
            env_lines.append(f"{k}={v}")

    if env_lines:
        patch_path = ".env.daa"
        with open(patch_path, "w") as f:
            f.write("# Generated by `daa init` — paste these into your .env\n")
            f.write("\n".join(env_lines) + "\n")
        ok(f"Wrote {len(env_lines)} env vars to {patch_path}")
        info(f"Run: cat {patch_path} >> .env  to apply them")

    # Register app via API
    if app_name and cfg.get("first_app"):
        header("Registering application in DAA…")
        try:
            fa = cfg["first_app"]
            res = requests.post(f"{backend}/applications/", json={
                "name": fa["name"],
                "repository_url": fa.get("repo_url", ""),
                "language": fa.get("language", "python"),
            }, timeout=5)
            if res.status_code in (200, 201):
                app_id = res.json().get("id")
                ok(f"Registered '{fa['name']}' (ID: {app_id})")
                # Set escalation policy
                requests.post(f"{backend}/applications/{app_id}/escalation-policies", json={
                    "rule_type": "error_rate_threshold",
                    "condition_value": int(fa.get("threshold", 3)),
                    "window_seconds": 60,
                    "cooldown_minutes": 30,
                }, timeout=5)
                ok(f"Escalation policy: escalate after {fa['threshold']} errors in 60s")
            else:
                warn(f"Could not register app (backend returned {res.status_code}) — run `docker-compose up` first")
        except Exception as e:
            warn(f"Backend not reachable: {e}. Start it with `docker-compose up -d`")

    header("━━━ Setup Complete! ━━━")
    print(f"\n  Next steps:")
    print(f"  {DIM}1.{RESET} Run:  {CYAN}docker-compose up -d{RESET}")
    print(f"  {DIM}2.{RESET} Open: {CYAN}http://localhost:5003{RESET}  (Admin Panel)")
    print(f"  {DIM}3.{RESET} Send a test error: {CYAN}daa test{RESET}")
    print()


def cmd_status(args):
    cfg = load_config()
    backend = cfg.get("backend_url", DEFAULT_BACKEND)

    header("━━━ DAA Service Health ━━━")

    # Backend
    try:
        r = requests.get(f"{backend}/health", timeout=4)
        if r.status_code == 200:
            ok(f"Backend API          {DIM}{backend}{RESET}")
        else:
            warn(f"Backend API returned {r.status_code}")
    except Exception:
        err(f"Backend API          unreachable at {backend}")

    # Dashboard
    try:
        r = requests.get(f"{backend}/dashboard", timeout=4)
        if r.status_code == 200:
            d = r.json()
            ok(f"Dashboard endpoint   active_incidents={d.get('active_incidents',0)}  fix_rate={d.get('fix_rate_percent',0)}%  alerts={d.get('active_alerts',0)}")
        else:
            warn(f"Dashboard endpoint   {r.status_code}")
    except Exception:
        err("Dashboard endpoint   unreachable")

    # Docker services
    services = ["daa-backend-api-1", "daa-python-agent-1", "daa-rabbitmq-1", "daa-postgres-1"]
    header("Docker Containers")
    for svc in services:
        result = subprocess.run(
            ["docker", "inspect", "--format", "{{.State.Status}}", svc],
            capture_output=True, text=True
        )
        status_str = result.stdout.strip()
        if status_str == "running":
            ok(f"{svc:<35} running")
        elif status_str:
            warn(f"{svc:<35} {status_str}")
        else:
            err(f"{svc:<35} not found")
    print()


def get_token() -> str:
    token = os.environ.get("DAA_TOKEN")
    if token:
        return token
    if os.path.exists(".env"):
        with open(".env") as f:
            for line in f:
                if line.startswith("DAA_TOKEN="):
                    return line.split("=", 1)[1].strip()
    return ""


def cmd_test(args):
    cfg = load_config()
    backend = cfg.get("backend_url", DEFAULT_BACKEND)

    header("━━━ DAA Pipeline Test ━━━")
    info("Sending a test RedisTimeoutError to DAA…")

    payload = {
        "app_name": cfg.get("first_app", {}).get("name", "test-service"),
        "content": "RedisTimeoutError: Connection timed out connecting to redis-master:6379 after 5000ms. Pool exhausted. [daa-test]",
        "exception_type": "RedisTimeoutError",
        "trace_id": f"daa-test-{int(time.time())}",
    }

    headers = {}
    token = get_token()
    if token:
        headers["Authorization"] = f"Bearer {token}"

    try:
        r = requests.post(f"{backend}/logs/", json=payload, headers=headers, timeout=6)
        if r.status_code in (200, 201, 202):
            resp = r.json()
            status = resp.get("status", "")
            ok(f"Error submitted! Status: {status}")
            if "Escalated" in status:
                ok("Threshold breached → Agent triggered!")
                info(f"Incident ID: {resp.get('incidentId','N/A')}")
            elif "Logged" in status:
                count = resp.get("error_count", "?")
                info(f"Error logged ({count} of threshold). Send more to trigger escalation.")
            elif "Suppressed" in status:
                info("Duplicate suppressed by SHA256 deduplication.")
            print(f"\n  Open Admin Panel: {CYAN}http://localhost:5003{RESET}")
        else:
            err(f"Backend returned {r.status_code}: {r.text[:200]}")
    except Exception as e:
        err(f"Could not reach backend at {backend}: {e}")
        info("Start DAA with: docker-compose up -d")
    print()


def cmd_logs(args):
    cfg = load_config()
    backend = cfg.get("backend_url", DEFAULT_BACKEND)

    header("━━━ Recent Incidents ━━━")
    try:
        r = requests.get(f"{backend}/incidents/", timeout=5)
        if r.status_code == 200:
            incidents = r.json()
            if not incidents:
                info("No incidents yet. Send an error with: daa test")
            else:
                for inc in incidents[:10]:
                    status_color = GREEN if inc["status"] == "resolved" else (RED if inc["status"] == "investigating" else YELLOW)
                    print(
                        f"  {status_color}{inc['status'].upper():<15}{RESET}"
                        f"  {inc['app_name']:<25}"
                        f"  {DIM}occurrences={inc.get('occurrence_count',1)}  "
                        f"fingerprint={inc.get('fingerprint','')[:12]}...{RESET}"
                    )
        else:
            err(f"Backend returned {r.status_code}")
    except Exception as e:
        err(f"Could not reach backend: {e}")
    print()


# ─────────────────────────────────────────────
# Entry Point
# ─────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(
        prog="daa",
        description="DAA v2.0 — Autonomous SRE Platform CLI",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Commands:
  init      Guided setup wizard (LLM + Git + Jira + first app)
  status    Health check all DAA services
  test      Send a test error and watch the pipeline
  logs      Show recent incidents
  version   Show version
        """,
    )
    subparsers = parser.add_subparsers(dest="command")
    subparsers.add_parser("init", help="Guided setup wizard")
    subparsers.add_parser("status", help="Health check all services")
    subparsers.add_parser("test", help="Send a test error")
    subparsers.add_parser("logs", help="Show recent incidents")
    subparsers.add_parser("version", help="Show version")

    args = parser.parse_args()

    commands = {
        "init": cmd_init,
        "status": cmd_status,
        "test": cmd_test,
        "logs": cmd_logs,
        "version": cmd_version,
    }

    if args.command in commands:
        commands[args.command](args)
    else:
        parser.print_help()


if __name__ == "__main__":
    main()
