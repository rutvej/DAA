def main():
    parser = argparse.ArgumentParser(
        prog="daa",
        description="DAA v2.0 — Autonomous SRE Platform CLI",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    subparsers = parser.add_subparsers(dest="command")

    # init
    subparsers.add_parser("init", help="Guided setup wizard")

    # register
    reg_parser = subparsers.add_parser("register", help="Register an application")
    reg_parser.add_argument("--name", help="Application name")
    reg_parser.add_argument("--repo-url", help="Repository URL")
    reg_parser.add_argument("--language", help="Application language")

    # policy
    pol_parser = subparsers.add_parser("policy", help="Set application escalation policy")
    pol_parser.add_argument("--app", help="Application name")
    pol_parser.add_argument("--threshold", type=int, help="Error threshold")
    pol_parser.add_argument("--window", type=int, help="Window in seconds")

    # mcp
    mcp_parser = subparsers.add_parser("mcp", help="Manage Model Context Protocol configurations")
    mcp_sub = mcp_parser.add_subparsers(dest="mcp_command")
    mcp_sub.add_parser("list", help="List configured MCP servers")
    
    mcp_add = mcp_sub.add_parser("add", help="Add an MCP server")
    mcp_add.add_argument("--name", required=True, help="MCP server name")
    mcp_add.add_argument("--cmd", required=True, help="Command to start server")
    mcp_add.add_argument("--args", help="Arguments as string or JSON list")
    mcp_add.add_argument("--env", help="Environment variables as JSON dictionary")

    mcp_remove = mcp_sub.add_parser("remove", help="Remove an MCP server")
    mcp_remove.add_argument("--name", required=True, help="MCP server name")

    # config
    cfg_parser = subparsers.add_parser("config", help="Manage LLM configurations")
    cfg_sub = cfg_parser.add_subparsers(dest="config_command")
    set_model_parser = cfg_sub.add_parser("set-model", help="Set model selection")
    set_model_parser.add_argument("--provider", required=True, help="LLM provider")
    set_model_parser.add_argument("--model", required=True, help="Model name")
    set_model_parser.add_argument("--api-key", help="API key")

    # redeploy
    subparsers.add_parser("redeploy", help="Redeploy DAA Services")

    # status, test, logs, version
    subparsers.add_parser("status", help="Health check all services")
    subparsers.add_parser("test", help="Send a test error")
    subparsers.add_parser("logs", help="Show recent incidents")
    subparsers.add_parser("version", help="Show version")

    args = parser.parse_args()

    commands = {
        "init": cmd_init,
        "register": cmd_register,
        "policy": cmd_policy,
        "mcp": cmd_mcp,
        "config": lambda a: cmd_config_set_model(a) if a.config_command == "set-model" else cfg_parser.print_help(),
        "redeploy": cmd_redeploy,
        "status": cmd_status,
        "test": cmd_test,
        "logs": cmd_logs,
        "version": cmd_version,
    }

    if args.command in commands:
        commands[args.command](args)
    else:
        parser.print_help()


if __name__ == "__main__":
    main()
