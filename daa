def cmd_version(_args):
    print(f"daa {VERSION} — DAA Autonomous SRE Platform")


def cmd_init(_args):
    header("━━━ DAA Setup Wizard ━━━")
    print(f"{DIM}This wizard configures Git repositories, LLM connection, and cloud access credentials.{RESET}\n")

    cfg = load_config()

    # ── Step 1: Git Provider & Credentials ──
    header("Step 1 — Git Provider & Credentials")
    git_provider = ask_choice(
        "Which Git provider hosts your application repositories?",
        ["github", "gitlab", "gitea"],
        default=cfg.get("GIT_PROVIDER", "github")
    )
    
    default_git_url = "https://github.com"
    if git_provider == "gitlab":
        default_git_url = "https://gitlab.com"
    elif git_provider == "gitea":
        default_git_url = "http://localhost:3000"

    git_url = ask("Git server base URL", cfg.get("GIT_URL", default_git_url))
    git_token = ask("Git Personal Access Token", cfg.get("GIT_TOKEN", ""), secret=True)

    cfg["GIT_PROVIDER"] = git_provider
    cfg["GIT_URL"] = git_url
    cfg["GIT_TOKEN"] = git_token

    # ── Step 2: LLM Configuration ──
    header("Step 2 — LLM Provider & Credentials")
    
    # Auto-detect existing keys
    detected_provider = None
    detected_key = None
    if os.environ.get("GEMINI_API_KEY"):
        detected_provider = "google"
        detected_key = os.environ.get("GEMINI_API_KEY")
    elif os.environ.get("OPENAI_API_KEY"):
        detected_provider = "openai"
        detected_key = os.environ.get("OPENAI_API_KEY")
    elif os.environ.get("ANTHROPIC_API_KEY"):
        detected_provider = "anthropic"
        detected_key = os.environ.get("ANTHROPIC_API_KEY")
        
    use_detected = "n"
    if detected_provider:
        print(f"  Detected existing credentials for LLM Provider: {GREEN}{detected_provider}{RESET}")
        use_detected = ask(f"  Would you like to use these detected credentials? [Y/n]", "Y")
        
    if use_detected.upper().startswith("Y") and detected_provider:
        llm_provider = detected_provider
        llm_key = detected_key
    else:
        llm_provider = ask_choice(
            "Select your active LLM provider:",
            ["google (Gemini)", "openai (GPT-4o)", "anthropic (Claude)", "vertex", "ollama (local)", "agy (CLI proxy)"],
            default="google (Gemini)"
        ).split(" ")[0]
        
        llm_key = ""
        if llm_provider not in ("vertex", "ollama", "agy"):
            llm_key = ask(f"Enter {llm_provider} API key", cfg.get("LLM_API_KEY", ""), secret=True)

    default_models = {
        "google": "gemini-1.5-flash",
        "openai": "gpt-4o-mini",
        "anthropic": "claude-3-5-sonnet-20241022",
        "vertex": "gemini-1.5-flash",
        "ollama": "llama3",
        "agy": "Gemini 3.5 Flash (Medium)"
    }
    
    llm_model = ask("Select model name", cfg.get("LLM_MODEL", default_models.get(llm_provider, "gemini-1.5-flash")))
    llm_base_url = ""
    if llm_provider == "ollama":
        llm_base_url = ask("Ollama API Base URL", cfg.get("LLM_BASE_URL", "http://localhost:11434/v1"))

    cfg["LLM_PROVIDER"] = llm_provider
    cfg["LLM_API_KEY"] = llm_key
    cfg["LLM_MODEL"] = llm_model
    if llm_base_url:
        cfg["LLM_BASE_URL"] = llm_base_url

    # ── Step 3: Cloud Logging Credentials (Skippable) ──
    header("Step 3 — Cloud Logging Access (Skippable)")
    configure_cloud_logs = ask("Configure Cloud Logging connector (AWS/GCP/Datadog) to pull live logs? [y/N]", "N")
    
    cloud_config = {}
    if configure_cloud_logs.upper().startswith("Y"):
        cloud_provider = ask_choice(
            "Select Cloud Logging provider:",
            ["AWS CloudWatch", "GCP Cloud Logging", "Datadog"],
            default="AWS CloudWatch"
        )
        cloud_config["provider"] = cloud_provider
        
        if cloud_provider == "AWS CloudWatch":
            cloud_config["aws_region"] = ask("AWS Region", "us-east-1")
            cloud_config["aws_access_key"] = ask("AWS Access Key ID", "")
            cloud_config["aws_secret_key"] = ask("AWS Secret Access Key", "", secret=True)
        elif cloud_provider == "GCP Cloud Logging":
            cloud_config["gcp_project_id"] = ask("GCP Project ID", "")
            cloud_config["gcp_credentials_json_path"] = ask("GCP Service Account JSON path", "")
        elif cloud_provider == "Datadog":
            cloud_config["dd_api_key"] = ask("Datadog API Key", "", secret=True)
            cloud_config["dd_app_key"] = ask("Datadog Application Key", "", secret=True)
            cloud_config["dd_site"] = ask("Datadog Site (e.g. datadoghq.com)", "datadoghq.com")
            
        cfg["cloud_logging"] = cloud_config
        ok(f"Cloud logging connector configured for {cloud_provider}")
    else:
        cfg["cloud_logging"] = None
        info("Cloud logging configuration skipped.")

    # ── Save and Write files ──
    save_config(cfg)
    
    # Pack env variables
    env_map = {
        "LLM_PROVIDER": llm_provider,
        "LLM_MODEL": llm_model,
        "SECRET_KEY": cfg.get("SECRET_KEY", "demo_secret_key"),
        "RABBITMQ_HOST": "rabbitmq",
    }
    
    # LLM Keys
    if llm_provider == "google":
        env_map["GEMINI_API_KEY"] = llm_key
    elif llm_provider == "openai":
        env_map["OPENAI_API_KEY"] = llm_key
    elif llm_provider == "anthropic":
        env_map["ANTHROPIC_API_KEY"] = llm_key
    if llm_base_url:
        env_map["LLM_BASE_URL"] = llm_base_url

    # Git Credentials
    if git_provider == "github":
        env_map["GITHUB_TOKEN"] = git_token
    elif git_provider == "gitlab":
        env_map["GITLAB_PRIVATE_TOKEN"] = git_token
        # Extract host
        from urllib.parse import urlparse
        parsed = urlparse(git_url)
        env_map["GITLAB_HOST"] = parsed.hostname or "gitlab"
    elif git_provider == "gitea":
        # Python agent connects via GitLab protocol usually for compatibility
        env_map["GITLAB_PRIVATE_TOKEN"] = git_token
        from urllib.parse import urlparse
        parsed = urlparse(git_url)
        env_map["GITLAB_HOST"] = parsed.hostname or "localhost"

    # Cloud Credentials
    if cfg["cloud_logging"]:
        cc = cfg["cloud_logging"]
        if cc["provider"] == "AWS CloudWatch":
            env_map["AWS_ACCESS_KEY_ID"] = cc.get("aws_access_key")
            env_map["AWS_SECRET_ACCESS_KEY"] = cc.get("aws_secret_key")
            env_map["AWS_REGION"] = cc.get("aws_region")
        elif cc["provider"] == "GCP Cloud Logging":
            env_map["GCP_PROJECT_ID"] = cc.get("gcp_project_id")
            env_map["GOOGLE_APPLICATION_CREDENTIALS"] = cc.get("gcp_credentials_json_path")
        elif cc["provider"] == "Datadog":
            env_map["DD_API_KEY"] = cc.get("dd_api_key")
            env_map["DD_APP_KEY"] = cc.get("dd_app_key")
            env_map["DD_SITE"] = cc.get("dd_site")

    write_env_vars(env_map)
    header("━━━ Setup Complete! ━━━")
    print(f"\n  To applyLLM configurations and deploy DAA services, run:")
    print(f"    {CYAN}daa redeploy{RESET}")
    print()


def cmd_register(args):
    cfg = load_config()
    backend = cfg.get("backend_url", DEFAULT_BACKEND)

    header("━━━ Register Application ━━━")

    # Read/ask args
    name = args.name or ask("Application name (e.g. checkout-service)")
    repo_url = args.repo_url or ask("Repository Git URL")
    language = args.language or ask_choice("Language/Runtime", ["python", "node", "go", "java", "ruby", "dotnet"], "python")

    if not name or not repo_url:
        err("Application name and repo URL are required to register.")
        sys.exit(1)

    # Get admin auth token
    admin_token = get_admin_token(backend)
    headers = {"Content-Type": "application/json"}
    if admin_token:
        headers["Authorization"] = f"Bearer {admin_token}"

    # 1. Register App
    info(f"Registering application '{name}' with backend...")
    app_payload = {
        "name": name,
        "language": language,
        "repository_url": repo_url,
    }
    
    try:
        res = requests.post(f"{backend}/applications/", json=app_payload, headers=headers, timeout=5)
        if res.status_code == 400 and "already exists" in res.text:
            warn(f"Application '{name}' already registered in DAA. Retrieving details...")
            # Fetch
            res_list = requests.get(f"{backend}/applications/", headers=headers, timeout=5)
            res_list.raise_for_status()
            app_data = next(a for a in res_list.json() if a["name"] == name)
        else:
            res.raise_for_status()
            app_data = res.json()
            
        app_token = app_data["token"]
        ok(f"Registered app '{name}'!")
        
        # 2. Register Project Git Connection
        git_prov = cfg.get("GIT_PROVIDER", "github")
        git_tok = cfg.get("GIT_TOKEN", "")
        
        info(f"Configuring project repository connection...")
        proj_payload = {
            "app_name": name,
            "repo_provider": git_prov,
            "repo_url": repo_url,
            "repo_token": git_tok
        }
        res_proj = requests.post(f"{backend}/projects/", json=proj_payload, headers=headers, timeout=5)
        res_proj.raise_for_status()
        ok(f"Linked repository credentials to '{name}'")

        # Output to user
        header("🔑 Telemetry Configuration Credentials")
        print(f"  {BOLD}DAA_TOKEN={app_token}{RESET}")
        print(f"  {BOLD}DAA_LOGS_URL={backend}/logs/{RESET}")
        print(f"\n  Inject these environment variables into your microservice deployment.")
        print(f"  SDK telemetry integration is now configured and ready to collect.")
        print()

    except Exception as e:
        err(f"Failed to register application: {e}")
        sys.exit(1)


def cmd_policy(args):
    cfg = load_config()
    backend = cfg.get("backend_url", DEFAULT_BACKEND)

    header("━━━ Configure Escalation Policy ━━━")
    app_name = args.app or ask("Application name")
    threshold = int(args.threshold or ask("Error threshold (N errors)", "3"))
    window = int(args.window or ask("Window size (seconds)", "60"))

    admin_token = get_admin_token(backend)
    headers = {"Content-Type": "application/json"}
    if admin_token:
        headers["Authorization"] = f"Bearer {admin_token}"

    try:
        # Get app ID from name
        res_list = requests.get(f"{backend}/applications/", headers=headers, timeout=5)
        res_list.raise_for_status()
        apps = res_list.json()
        app = next((a for a in apps if a["name"] == app_name), None)
        if not app:
            err(f"Application '{app_name}' not found. Register it first using: daa register")
            sys.exit(1)

        app_id = app["id"]
        policy_payload = {
            "rule_type": "error_rate_threshold",
            "condition_value": threshold,
            "window_seconds": window,
            "cooldown_minutes": 30,
            "severity_keywords": ["FATAL", "OOMKill", "RedisConnectionError", "ConnectionRefusedError", "InternalServerError"]
        }
        
        res = requests.post(f"{backend}/applications/{app_id}/escalation-policies", json=policy_payload, headers=headers, timeout=5)
        res.raise_for_status()
        ok(f"Escalation Policy updated for '{app_name}': Escalate if > {threshold} errors occur within {window} seconds.")
        print()

    except Exception as e:
        err(f"Failed to configure escalation policy: {e}")
        sys.exit(1)


def cmd_mcp(args):
    config_path = "mcp_config.json"
    
    # Load existing config
    mcp_data = {"mcpServers": {}}
    if os.path.exists(config_path):
        try:
            with open(config_path, "r") as f:
                mcp_data = json.load(f)
        except Exception:
            pass

    if args.mcp_command == "list":
        header("━━━ Configured MCP Servers ━━━")
        servers = mcp_data.get("mcpServers", {})
        if not servers:
            info("No external MCP servers configured in mcp_config.json")
        else:
            for name, sc in servers.items():
                print(f"  {BOLD}{name}{RESET}")
                print(f"    Command: {sc.get('command')}")
                print(f"    Args:    {sc.get('args', [])}")
                if sc.get("env"):
                    print(f"    Env:     {sc.get('env')}")
                print()
                
    elif args.mcp_command == "add":
        if not args.name or not args.cmd:
            err("Adding MCP requires --name and --cmd flags.")
            sys.exit(1)
            
        # Parse args JSON
        parsed_args = []
        if args.args:
            try:
                parsed_args = json.loads(args.args)
                if not isinstance(parsed_args, list):
                    parsed_args = [str(parsed_args)]
            except Exception:
                parsed_args = [args.args]
                
        # Parse env JSON
        parsed_env = {}
        if args.env:
            try:
                parsed_env = json.loads(args.env)
            except Exception:
                err("Env must be a valid JSON dictionary.")
                sys.exit(1)

        mcp_data.setdefault("mcpServers", {})[args.name] = {
            "command": args.cmd,
            "args": parsed_args
        }
        if parsed_env:
            mcp_data["mcpServers"][args.name]["env"] = parsed_env
            
        with open(config_path, "w") as f:
            json.dump(mcp_data, f, indent=2)
        ok(f"MCP server '{args.name}' added successfully to mcp_config.json")
        
    elif args.mcp_command == "remove":
        if not args.name:
            err("Removing MCP requires the --name flag.")
            sys.exit(1)
            
        servers = mcp_data.get("mcpServers", {})
        if args.name in servers:
            del servers[args.name]
            with open(config_path, "w") as f:
                json.dump(mcp_data, f, indent=2)
            ok(f"MCP server '{args.name}' removed from mcp_config.json")
        else:
            err(f"MCP server '{args.name}' not found.")
            sys.exit(1)


def cmd_config_set_model(args):
    if not args.provider or not args.model:
        err("set-model requires --provider and --model flags.")
        sys.exit(1)

    header("━━━ Update Model Configuration ━━━")
    cfg = load_config()

    cfg["LLM_PROVIDER"] = args.provider
    cfg["LLM_MODEL"] = args.model
    if args.api_key:
        cfg["LLM_API_KEY"] = args.api_key

    save_config(cfg)

    # Build update env mapping
    env_map = {
        "LLM_PROVIDER": args.provider,
        "LLM_MODEL": args.model
    }
    if args.api_key:
        if args.provider == "google":
            env_map["GEMINI_API_KEY"] = args.api_key
        elif args.provider == "openai":
            env_map["OPENAI_API_KEY"] = args.api_key
        elif args.provider == "anthropic":
            env_map["ANTHROPIC_API_KEY"] = args.api_key

    write_env_vars(env_map)
    ok(f"Updated LLM configuration to: provider={args.provider}, model={args.model}")
    info("To redeploy services with the new model, run: daa redeploy")
    print()


def cmd_redeploy(_args):
    header("━━━ Redeploy DAA Services ━━━")
    info("Restarting Docker containers to apply latest configurations...")

    # Detect compose command
    compose_cmd = "docker-compose"
    try:
        subprocess.run(["docker-compose", "version"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=True)
    except Exception:
        try:
            subprocess.run(["docker", "compose", "version"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=True)
            compose_cmd = "docker compose"
        except Exception:
            err("Neither docker-compose nor docker compose could be found.")
            sys.exit(1)

    try:
        # Run down
        info("Stopping active containers...")
        subprocess.run(f"{compose_cmd} down", shell=True, check=True)
        # Run up
        info("Building and starting containers in background...")
        subprocess.run(f"{compose_cmd} up -d --build", shell=True, check=True)
        ok("DAA Services successfully rebuilt and redeployed!")
        print()
    except subprocess.CalledProcessError as e:
        err(f"Redeployment failed: {e}")
        sys.exit(1)


def cmd_status(args):
    cfg = load_config()
    backend = cfg.get("backend_url", DEFAULT_BACKEND)

    header("━━━ DAA Service Health ━━━")

    # Backend
    try:
        r = requests.get(f"{backend}/health", timeout=4)
        if r.status_code == 200:
            ok(f"Backend API          {DIM}{backend}{RESET}")
        else:
            warn(f"Backend API returned {r.status_code}")
    except Exception:
        err(f"Backend API          unreachable at {backend}")

    # Dashboard
    try:
        r = requests.get(f"{backend}/dashboard", timeout=4)
        if r.status_code == 200:
            d = r.json()
            ok(f"Dashboard endpoint   active_incidents={d.get('active_incidents',0)}  fix_rate={d.get('fix_rate_percent',0)}%  alerts={d.get('active_alerts',0)}")
        else:
            warn(f"Dashboard endpoint   {r.status_code}")
    except Exception:
        err("Dashboard endpoint   unreachable")

    # Docker services
    services = ["daa-backend-api-1", "daa-python-agent-1", "daa-rabbitmq-1", "daa-postgres-1"]
    header("Docker Containers")
    for svc in services:
        result = subprocess.run(
            ["docker", "inspect", "--format", "{{.State.Status}}", svc],
            capture_output=True, text=True
        )
        status_str = result.stdout.strip()
        if status_str == "running":
            ok(f"{svc:<35} running")
        elif status_str:
            warn(f"{svc:<35} {status_str}")
        else:
            err(f"{svc:<35} not found")
    print()


def cmd_test(args):
    cfg = load_config()
    backend = cfg.get("backend_url", DEFAULT_BACKEND)

    header("━━━ DAA Pipeline Test ━━━")
    info("Sending a test RedisTimeoutError to DAA…")

    payload = {
        "app_name": cfg.get("first_app", {}).get("name", "test-service"),
        "content": "RedisTimeoutError: Connection timed out connecting to redis-master:6379 after 5000ms. Pool exhausted. [daa-test]",
        "exception_type": "RedisTimeoutError",
        "trace_id": f"daa-test-{int(time.time())}",
    }

    headers = {}
    token = get_token()
    if token:
        headers["Authorization"] = f"Bearer {token}"

    try:
        r = requests.post(f"{backend}/logs/", json=payload, headers=headers, timeout=6)
        if r.status_code in (200, 201, 202):
            resp = r.json()
            status = resp.get("status", "")
            ok(f"Error submitted! Status: {status}")
            if "Escalated" in status:
                ok("Threshold breached → Agent triggered!")
                info(f"Incident ID: {resp.get('incidentId','N/A')}")
            elif "Logged" in status:
                count = resp.get("error_count", "?")
                info(f"Error logged ({count} of threshold). Send more to trigger escalation.")
            elif "Suppressed" in status:
                info("Duplicate suppressed by SHA256 deduplication.")
            print(f"\n  Open Admin Panel: {CYAN}http://localhost:5003{RESET}")
        else:
            err(f"Backend returned {r.status_code}: {r.text[:200]}")
    except Exception as e:
        err(f"Could not reach backend at {backend}: {e}")
        info("Start DAA with: docker-compose up -d")
    print()


def cmd_logs(args):
    cfg = load_config()
    backend = cfg.get("backend_url", DEFAULT_BACKEND)

    header("━━━ Recent Incidents ━━━")
    try:
        r = requests.get(f"{backend}/incidents/", timeout=5)
        if r.status_code == 200:
            incidents = r.json()
            if not incidents:
                info("No incidents yet. Send an error with: daa test")
            else:
                for inc in incidents[:10]:
                    status_color = GREEN if inc["status"] == "resolved" else (RED if inc["status"] == "investigating" else YELLOW)
                    print(
                        f"  {status_color}{inc['status'].upper():<15}{RESET}"
                        f"  {inc['app_name']:<25}"
                        f"  {DIM}occurrences={inc.get('occurrence_count',1)}  "
                        f"fingerprint={inc.get('fingerprint','')[:12]}...{RESET}"
                    )
        else:
            err(f"Backend returned {r.status_code}")
    except Exception as e:
        err(f"Could not reach backend: {e}")
    print()


